# Backend .env — used for local non-Docker development.
# Copy to backend/.env and adjust.

SENTINEL_DATABASE_URL=postgresql+psycopg://sentinelai:sentinelai@localhost:5432/sentinelai
SENTINEL_API_KEY=dev-api-key-change-me
SENTINEL_JWT_SECRET=dev-jwt-secret-change-me
SENTINEL_CORS_ORIGINS=http://localhost:5173
SENTINEL_LOG_LEVEL=info
SENTINEL_ENV=development

# Auth tokens + cookies. Access tokens are short-lived; refresh tokens live in an
# httpOnly cookie. Production defaults are Secure — but browsers DROP Secure
# cookies over http://localhost, so set SECURE=false for non-HTTPS local dev.
SENTINEL_ACCESS_TOKEN_TTL_MINUTES=15
SENTINEL_REFRESH_TOKEN_TTL_DAYS=7
SENTINEL_AUTH_COOKIE_SECURE=false
SENTINEL_AUTH_COOKIE_SAMESITE=lax
# SENTINEL_AUTH_COOKIE_DOMAIN=

# Account lockout (separate from rate limiting): N failures within the window
# locks the account for the lockout duration. Admin reset via the unlock endpoint.
SENTINEL_LOGIN_MAX_FAILED_ATTEMPTS=5
SENTINEL_LOGIN_FAILED_WINDOW_MINUTES=15
SENTINEL_LOGIN_LOCKOUT_MINUTES=15

# HTTP security headers. HSTS auto-enables in production; force it on here only
# when TLS terminates in front of the app (see docs/DEPLOYMENT_SECURITY.md).
SENTINEL_SECURITY_HEADERS_ENABLED=true
SENTINEL_SECURITY_HSTS_ENABLED=false

# Observability. Prometheus /metrics is on by default (restrict at the network
# in prod). OpenTelemetry tracing is opt-in: install the otel extra and set
# enabled=true + an OTLP endpoint (see docs/DEPLOYMENT_SECURITY.md).
SENTINEL_METRICS_ENABLED=true
SENTINEL_OTEL_ENABLED=false
# SENTINEL_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SENTINEL_OTEL_SERVICE_NAME=sentinelai-backend

# Rate limiting. In production Redis is required (the app refuses to start
# without it); in development it falls back to an in-process limiter + a warning.
SENTINEL_REDIS_URL=redis://localhost:6379/0
SENTINEL_RATE_LIMIT_ENABLED=true
# Optional overrides — "<count>/<second|minute|hour>"
# SENTINEL_RATE_LIMIT_LOGIN=5/minute
# SENTINEL_RATE_LIMIT_AUTHENTICATED=120/minute
# SENTINEL_RATE_LIMIT_INGEST=10/minute
# SENTINEL_RATE_LIMIT_DETECTION=5/minute
# SENTINEL_RATE_LIMIT_REPORT=20/minute
# SENTINEL_RATE_LIMIT_RESPONSE=60/minute

# Live-sensor batch ingest: run detection automatically after each batch.
# Off by default; opt-in for the live-sensor demo. See docs/LIVE_SENSOR.md.
SENTINEL_DETECTION_AUTO_RUN_ON_INGEST=false

# Async task queue (arq, Redis-backed). The worker runs `arq app.worker.WorkerSettings`.
# Without Redis, enqueue is a no-op (tasks stay PENDING). See docs/TASK_QUEUE.md.
SENTINEL_TASK_QUEUE_NAME=sentinelai:queue
SENTINEL_RATE_LIMIT_TASKS=30/minute
SENTINEL_RETENTION_DAYS=90
SENTINEL_ML_RETRAIN_ENABLED=false

# Data retention (age in days; 0 = DISABLED = safe default — nothing deleted).
# Events are hard-deleted; alerts + reports are soft-archived. See DATA_RETENTION.md.
# Always `make retention-dry-run` (and back up) before enabling on real data.
SENTINEL_RETENTION_EVENTS_DAYS=0
SENTINEL_RETENTION_ALERTS_DAYS=0
SENTINEL_RETENTION_REPORTS_DAYS=0

# Response execution. Simulated by default; LAB (real, allowlisted, approved,
# reversible) effects require ALL of the below + analyst approval. Lab-only,
# never production. See docs/LAB_RESPONSE.md.
SENTINEL_RESPONSE_MODE=simulated          # simulated | lab
SENTINEL_RESPONSE_ENABLED=false
SENTINEL_RESPONSE_EXECUTOR=simulated      # simulated | mock_lab | nftables_lab
SENTINEL_RESPONSE_ALLOWED_CIDRS=          # required for LAB, e.g. 10.0.0.0/8,192.168.0.0/16
SENTINEL_RESPONSE_MAX_BLOCK_MINUTES=60
SENTINEL_RESPONSE_REQUIRE_APPROVAL=true

# Bootstrap admin — created once on startup if BOTH are set. Leave unset to
# skip (no default user is ever created). Rotate before any shared deployment.
# NOTE: the password must satisfy the policy (12+ chars; 3+ of lower/upper/
# number/symbol; must NOT contain the username). Bootstrap fails otherwise.
SENTINEL_BOOTSTRAP_ADMIN_USERNAME=admin
SENTINEL_BOOTSTRAP_ADMIN_PASSWORD=Change-Me-Now-2026!
