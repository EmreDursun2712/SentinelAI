# Root .env — consumed by docker-compose.yml.
# Copy this file to .env and adjust as needed.

# ---- Postgres ----
POSTGRES_USER=sentinelai
POSTGRES_PASSWORD=sentinelai
POSTGRES_DB=sentinelai
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_API_KEY=dev-api-key-change-me
BACKEND_JWT_SECRET=dev-jwt-secret-change-me
BACKEND_CORS_ORIGINS=http://localhost:5173

# Bootstrap admin — created once on first startup if BOTH are set. Leave unset
# to skip. No default user is ever created. Rotate before any shared deployment.
BACKEND_BOOTSTRAP_ADMIN_USERNAME=admin
BACKEND_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-pw

# ---- Frontend ----
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1
