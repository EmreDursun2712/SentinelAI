# Root .env — consumed by docker-compose.yml.
# Copy this file to .env and adjust as needed.

# ---- Postgres ----
POSTGRES_USER=sentinelai
POSTGRES_PASSWORD=sentinelai
POSTGRES_DB=sentinelai
POSTGRES_PORT=5432

# ---- Redis (rate limiting) ----
REDIS_PORT=6379
BACKEND_REDIS_URL=redis://redis:6379/0
BACKEND_RATE_LIMIT_ENABLED=true

# ---- Backend ----
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_API_KEY=dev-api-key-change-me
BACKEND_JWT_SECRET=dev-jwt-secret-change-me
BACKEND_CORS_ORIGINS=http://localhost:5173

# Bootstrap admin — created once on first startup if BOTH are set. Leave unset
# to skip. No default user is ever created. Rotate before any shared deployment.
BACKEND_BOOTSTRAP_ADMIN_USERNAME=admin
BACKEND_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-pw

# ---- Frontend ----
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1

# ---- Live sensor (LAB ONLY, off by default; profile: sensor) ----
# Run with: docker compose --profile sensor up sensor
# Authorized lab networks only — see docs/LIVE_SENSOR.md.
BACKEND_DETECTION_AUTO_RUN_ON_INGEST=false   # backend: run detection after each batch
SENSOR_ENABLED=false                          # must be true for the sensor to start
SENSOR_MODE=pcap_replay                        # zeek | suricata | pcap_replay
SENSOR_INPUT_PATH=/logs/conn.log               # path inside the sensor container
SENSOR_LOG_DIR=./sensor/samples                # host dir mounted read-only at /logs
SENSOR_ALLOWED_CIDRS=                          # REQUIRED, e.g. 192.168.0.0/16,10.0.0.0/8
SENSOR_API_URL=http://backend:8000
SENSOR_API_TOKEN=                              # JWT for an ANALYST/ADMIN user
SENSOR_BATCH_SIZE=100
SENSOR_INTERVAL_SECONDS=2
